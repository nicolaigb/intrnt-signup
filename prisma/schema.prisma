generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Signup {
  id        Int      @id @default(autoincrement())
  name      String
  email     String  @unique
  createdAt DateTime @default(now()) @map("created_at")
  @@map("signup")
}
